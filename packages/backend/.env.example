# DistriBank Backend — Variables de entorno
# Copiar a .env y completar con valores reales. NO commitear .env.

# ─────────────────────────────────────────────────────────────────────────────
# Nodos PostgreSQL (Supabase) — 3 proyectos en regiones distintas
#
# Formato de conexión directa (puerto 5432, recomendada para Prisma):
#   postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
#
# Obtener la URL desde:
#   Supabase Dashboard → Settings → Database → Connection string → URI (Direct connection)
#
# ⚠ NO usar el pooler (puerto 6543) con Prisma en modo server-side long-lived.
#   El pooler es para serverless/edge functions.
# ─────────────────────────────────────────────────────────────────────────────

# Nodo A — customer_id % 3 = 0 (incluye Natalia, id=27)
# Región recomendada: South America (São Paulo)
NODE_A_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF-NODO-A].supabase.co:5432/postgres?sslmode=require

# Nodo B — customer_id % 3 = 1
# Región recomendada: US East (N. Virginia)
NODE_B_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF-NODO-B].supabase.co:5432/postgres?sslmode=require

# Nodo C — customer_id % 3 = 2 · También aloja schema distribank_vip_customers
# Proyecto existente: cllzymmcacyohsjuwibe.supabase.co
NODE_C_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.cllzymmcacyohsjuwibe.supabase.co:5432/postgres?sslmode=require

# ─────────────────────────────────────────────────────────────────────────────
# Autenticación JWT
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=distribank-dev-secret-change-in-production
JWT_EXPIRES_IN=3600
